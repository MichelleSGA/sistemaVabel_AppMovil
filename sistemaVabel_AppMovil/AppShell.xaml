<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="sistemaVabel_AppMovil.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:sistemaVabel_AppMovil"
    xmlns:views="clr-namespace:sistemaVabel_AppMovil.Views"
    Title="Vabel Movil">

    <TabBar>
        <Tab Title="Inicio" >
            <ShellContent
                Title="Home"
                ContentTemplate="{DataTemplate views:MainPage}"
                Route="MainPage" />
        </Tab>

        <Tab Title="Contabilidad" >
            <ShellContent
                Title="Ventas"
                ContentTemplate="{DataTemplate views:LibretaVentasPage}"
                Route="LibretaVentasPage" />
        </Tab>
    </TabBar>
    <ShellContent
        Shell.NavBarIsVisible="False"
        ContentTemplate="{DataTemplate views:InventarioPage}"
        Route="Inventario" />


</Shell>
