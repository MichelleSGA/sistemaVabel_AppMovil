<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:sistemaVabel_AppMovil.ViewModels"
             x:Class="sistemaVabel_AppMovil.Views.HistorialGastosPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="White">
    <ContentPage.BindingContext>
        <viewmodels:HistorialGastosViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="20, 40, 20, 20" BackgroundColor="{StaticResource Primary}">
            <Label Grid.Column="0" Text="&#xe5c4;" FontFamily="MaterialIcons" FontSize="28" TextColor="White" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding VolverCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <Label Grid.Column="1" Text="Historial de Gastos" TextColor="White" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <!-- Se eliminó Padding de CollectionView y se envolvió en un contenedor con Padding -->
        <Grid Grid.Row="1" Padding="20">
            <CollectionView ItemsSource="{Binding ListaGastos}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="15" StrokeShape="RoundRectangle 10" BackgroundColor="#F9F9F9" Stroke="Transparent">
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding descripcion}" FontAttributes="Bold" FontSize="16" TextColor="Black"/>

                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding fecha, StringFormat='{0:dd/MM/yyyy}'}" FontSize="12" TextColor="Gray"/>

                                <Label Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Text="{Binding monto, StringFormat='${0:F2}'}" FontAttributes="Bold" FontSize="18" TextColor="#E53935" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,50,0,0">
                        <Label Text="&#xe88b;" FontFamily="MaterialIcons" FontSize="50" TextColor="LightGray" HorizontalOptions="Center"/>
                        <Label Text="Aún no hay gastos registrados." TextColor="Gray" FontSize="16" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>