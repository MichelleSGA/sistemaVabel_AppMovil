             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="sistemaVabel_AppMovil.Views.BalanceGeneralPage"
             BackgroundColor="{StaticResource Primary}">

    <ScrollView Grid.Row="0" Padding="16,0,16,20">
        <VerticalStackLayout Spacing="16">

            <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,16,0,8">
